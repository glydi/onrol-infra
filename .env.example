# ─── Server ───────────────────────────────────────────────────────────────
APP_ENV=development            # development | production
PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────
# In Docker Compose the host is the service name "postgres".
POSTGRES_USER=onrol
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=onrol
DATABASE_URL=postgres://onrol:change-me-strong@postgres:5432/onrol?sslmode=disable

# ─── Auth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-random-hex
JWT_ACCESS_TTL=24h
MAX_DEVICES_PER_USER=2

# Device attestation enforcement:
#   off     - ignore attestation entirely (dev only)
#   log     - record attestation result but always allow (ship-first default)
#   enforce - reject devices that fail Play Integrity / App Attest
ATTESTATION_MODE=log

# Admin endpoints (POST /api/v1/admin/*) require this in the X-Admin-Key header.
# Leave empty to disable admin routes entirely. Generate: openssl rand -hex 24
ADMIN_API_KEY=

# ─── Zoho Webinar ─────────────────────────────────────────────────────────
# Regional base only (.in for India). Per-webinar tokens (embed sessionId,
# web-form digest/enc/sysId) are stored in the DB via POST /api/v1/admin/webinars
# — copy them from your webinar's embed registration form HTML.
ZOHO_WEBINAR_BASE=https://webinar.zoho.in

# ─── Zoho spike test inputs (cmd/zoho-spike only) ─────────────────────────
# Paste the hidden values from your embed registration form to validate whether
# a server-side POST returns a join URL or just emails it.
ZOHO_TEST_WEBFORM_URL=https://webinar.zoho.in/meeting/WebForm
ZOHO_TEST_SYS_ID=
ZOHO_TEST_DIGEST=
ZOHO_TEST_ENC=
ZOHO_TEST_RETURN_URL=https://webinar.zoho.in/postregister
ZOHO_TEST_EMAIL=spike-student@example.com
ZOHO_TEST_NAME=Spike Student

# ─── Cloudflare R2 (used by offline packaging scripts, not the API) ───────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=onrol-vod
