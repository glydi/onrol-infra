# ─── Server ───────────────────────────────────────────────────────────────
APP_ENV=development            # development | production
PORT=8080

# ─── Database ─────────────────────────────────────────────────────────────
# In Docker Compose the host is the service name "postgres".
POSTGRES_USER=onrol
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=onrol
DATABASE_URL=postgres://onrol:change-me-strong@postgres:5432/onrol?sslmode=disable

# ─── Auth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-random-hex
JWT_ACCESS_TTL=24h
MAX_DEVICES_PER_USER=2

# Device attestation enforcement:
#   off     - ignore attestation entirely (dev only)
#   log     - record attestation result but always allow (ship-first default)
#   enforce - reject devices that fail Play Integrity / App Attest
ATTESTATION_MODE=log

# Admin endpoints (POST /api/v1/admin/*) require this in the X-Admin-Key header.
# Leave empty to disable admin routes entirely. Generate: openssl rand -hex 24
ADMIN_API_KEY=

# ─── Zoho Webinar ─────────────────────────────────────────────────────────
# Regional base only (.in for India). Per-webinar tokens (embed sessionId,
# web-form digest/enc/sysId) are stored in the DB via POST /api/v1/admin/webinars
# — copy them from your webinar's embed registration form HTML.
ZOHO_WEBINAR_BASE=https://webinar.zoho.in

# ─── Zoho REST API v2 (real registration path) ────────────────────────────
# When all of ORG_ID + OAUTH_* are set, /live registers the student server-side
# via POST /api/v2/{org}/register/{meetingKey}.json and returns a private join
# link (scope: ZohoMeeting.webinar.READ,ZohoMeeting.webinar.CREATE). Left empty,
# live join falls back to the embed widget. Per-webinar: store embed_session_id
# (== meetingKey) and zoho_instance_id (the webinar sysId) on the webinar row.
ZOHO_API_BASE=https://meeting.zoho.in/api/v2
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.in
ZOHO_ORG_ID=
ZOHO_OAUTH_CLIENT_ID=
ZOHO_OAUTH_CLIENT_SECRET=
ZOHO_OAUTH_REFRESH_TOKEN=
# Required to CREATE webinars from the app (Add Live Class → "Zoho webinar").
# The presenter's Zoho user id (zuid); webinar timezone defaults to Asia/Kolkata.
ZOHO_PRESENTER_ZUID=
ZOHO_TIMEZONE=Asia/Kolkata

# ─── Zoho spike test inputs (cmd/zoho-spike only) ─────────────────────────
# Paste the hidden values from your embed registration form to validate whether
# a server-side POST returns a join URL or just emails it.
ZOHO_TEST_WEBFORM_URL=https://webinar.zoho.in/meeting/WebForm
ZOHO_TEST_SYS_ID=
ZOHO_TEST_DIGEST=
ZOHO_TEST_ENC=
ZOHO_TEST_RETURN_URL=https://webinar.zoho.in/postregister
ZOHO_TEST_EMAIL=spike-student@example.com
ZOHO_TEST_NAME=Spike Student

# ─── Cloudflare R2 (VOD storage + backups; used by scripts/r2.sh) ─────────
R2_ACCOUNT_ID=654ba212c64772676db80c1abf1499f8
R2_ACCESS_KEY_ID=            # R2 → Manage R2 API Tokens → "S3 clients" Access Key ID
R2_SECRET_ACCESS_KEY=        # … and Secret Access Key (shown once)
R2_BUCKET=onrol-vod
# Public base for playable URLs (bucket Public Dev URL or a connected custom domain):
R2_PUBLIC_BASE=https://pub-73686d7308e6498ebe8f396f9306fdd3.r2.dev
